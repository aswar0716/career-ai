generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum SkillLevel {
  LEARNING
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum SkillCategory {
  ML_FRAMEWORKS
  PYTHON_LIBS
  LLM_TOOLS
  MLOPS
  CLOUD
  PROGRAMMING
  DATA_ENGINEERING
  TOOLS
  MATH_STATS
  SOFT_SKILLS
}

enum ProjectType {
  PERSONAL
  OPEN_SOURCE
  RESEARCH
  PROFESSIONAL
  COMPETITION
}

enum ResourceType {
  COURSE
  BOOK
  PAPER
  VIDEO
  ARTICLE
  PRACTICE
}

enum ResourceStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PAUSED
}

model JobApplication {
  id            String            @id @default(cuid())
  company       String
  role          String
  location      String?
  url           String?
  status        ApplicationStatus @default(APPLIED)
  priority      Priority          @default(MEDIUM)
  appliedAt     DateTime          @default(now())
  notes         String?
  salary        String?
  interviewDate DateTime?
  contactName   String?
  contactEmail  String?
  nextAction    String?
  resumeId      String?
  resume        Resume?           @relation(fields: [resumeId], references: [id])
  coverLetterId String?
  coverLetter   CoverLetter?      @relation(fields: [coverLetterId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([company, role], name: "company_role")
  @@index([status])
  @@index([appliedAt])
}

model Resume {
  id           String         @id @default(cuid())
  name         String
  targetRole   String?
  content      String
  skills       String?
  atsScore     Int?
  isDefault    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  coverLetters CoverLetter[]
  applications JobApplication[]
}

model CoverLetter {
  id           String         @id @default(cuid())
  name         String
  content      String
  jobTitle     String?
  company      String?
  resumeId     String?
  resume       Resume?        @relation(fields: [resumeId], references: [id])
  applications JobApplication[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Skill {
  id        String        @id @default(cuid())
  name      String        @unique
  category  SkillCategory
  level     SkillLevel    @default(BEGINNER)
  yearsExp  Float?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?
  githubUrl   String?
  demoUrl     String?
  paperUrl    String?
  techStack   String?
  highlights  String?
  type        ProjectType @default(PERSONAL)
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model DailyLog {
  id               String   @id @default(cuid())
  date             DateTime @unique
  mood             Int      @default(3)
  energy           Int      @default(3)
  applicationsGoal Int      @default(3)
  applicationsDone Int      @default(0)
  studyMinutes     Int      @default(0)
  exercised        Boolean  @default(false)
  notes            String?
  gratitude        String?
  wins             String?
  blockers         String?
  tomorrowPlan     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LearningResource {
  id          String         @id @default(cuid())
  title       String
  url         String?
  type        ResourceType
  topic       String
  status      ResourceStatus @default(NOT_STARTED)
  priority    Int            @default(2)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}
